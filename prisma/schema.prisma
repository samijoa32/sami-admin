// 사미반점 온라인 주문 시스템 — 데이터베이스 스키마
// 개발: SQLite / 운영: Postgres(Supabase)로 provider만 교체하면 됩니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── 배달비 설정 ─────────────────────────────────
// 단일 행만 사용 (id를 고정값으로 둠)
model DeliverySetting {
  id              String @id @default("delivery_setting")
  deliveryFee     Int    @default(3000)  // 기본 배달비
  freeThreshold   Int    @default(15000) // 이 금액 이상이면 배달비 무료 (0이면 항상 부과)
}

// ── 매장 ──────────────────────────────────────
model Store {
  id        String   @id @default(cuid())
  name      String   // "하남 본점" | "미사2호점"
  slug      String   @unique // "main" | "misa2"
  address   String?
  phone     String?
  createdAt DateTime @default(now())

  menus  Menu[]
  orders Order[]
}

// ── 카테고리 ──────────────────────────────────
model Category {
  id        String @id @default(cuid())
  name      String
  sortOrder Int    @default(0)

  menus Menu[]
}

// ── 메뉴 ──────────────────────────────────────
model Menu {
  id          String   @id @default(cuid())
  name        String
  price       Int
  imageUrl    String?
  description String?
  soldOut     Boolean  @default(false)
  createdAt   DateTime @default(now())

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  orderItems OrderItem[]
}

// ── 주문 ──────────────────────────────────────
// 참고: SQLite는 enum을 지원하지 않아 String으로 관리합니다.
// orderType: "dine_in" | "takeout" | "delivery"
// status:    "pending" | "cooking" | "done"

model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique // 사람이 보는 짧은 주문번호 (예: 0042)
  orderType   String
  status      String   @default("pending")
  tableNumber String?
  deliveryFee Int      @default(0) // 배달 주문일 때만 값이 들어감 (메뉴 금액 합계에는 미포함)
  totalAmount Int      // 메뉴 합계 + 배달비
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  items OrderItem[]
}

// ── 주문 항목 ─────────────────────────────────
model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Int // 주문 시점 가격 (메뉴 가격이 나중에 바뀌어도 주문 기록은 보존)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id])
}
